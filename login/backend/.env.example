# ============================================
# 技术监督辅助平台 - 环境变量模板
# 说明：复制本文件为 .env，并填写真实值
# ============================================

# 数据库连接（MySQL）
DATABASE_URL=mysql+pymysql://root:password@localhost/power_knowledge_management

# JWT 密钥（请使用随机生成的强密码）
SECRET_KEY=your-secret-key-change-in-production

# Redis 连接
REDIS_URL=redis://localhost:6379/0

# 邮箱 SMTP 配置（用于发送验证码）
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=your_email@163.com
SMTP_PASSWORD=your_auth_code        # 163邮箱授权码，非邮箱密码
SMTP_FROM=your_email@163.com

# MinIO 对象存储配置
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=tech-platform
MINIO_SECURE=False

# 阿里云短信认证服务（若不需要可留空）
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=

# 其他配置（使用默认值时可不填）
# ACCESS_TOKEN_EXPIRE_MINUTES=120
# FREEZE_DURATION_HOURS=12
# MAX_LOGIN_ATTEMPTS_BEFORE_FREEZE=5
# REQUIRE_CAPTCHA_AFTER_FAILURES=2