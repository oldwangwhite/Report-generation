APP_NAME=report-generation-backend
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/power_knowledge_management?charset=utf8mb4

UPLOAD_DIR=./uploads
EXPORT_DIR=./exports
MAX_UPLOAD_SIZE_MB=50
ENABLE_STATIC_TEST_TOKENS=false
EXPOSE_DEV_VERIFICATION_CODES=false
VERIFICATION_CODE_TTL_MINUTES=5
VERIFICATION_CODE_COOLDOWN_SECONDS=60

# 邮箱 SMTP 配置，用于发送邮箱验证码。
# 例如 163 邮箱使用授权码，不是登录密码。
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=your_email@163.com
SMTP_PASSWORD=your_smtp_auth_code
SMTP_FROM=your_email@163.com
SMTP_USE_SSL=true
SMTP_USE_STARTTLS=false
SMTP_TIMEOUT_SECONDS=10

# 短信 HTTP 网关配置。将 $phone 和 $code 写入服务商请求模板。
# 示例：
# SMS_HTTP_URL=https://sms-provider.example/send
# SMS_HTTP_METHOD=POST
# SMS_HTTP_HEADERS_JSON={"Authorization":"Bearer your-token"}
# SMS_HTTP_BODY_TEMPLATE={"phone":"$phone","content":"您的验证码是 $code，5 分钟内有效。"}
# SMS_HTTP_SUCCESS_STATUS=200,201,202
SMS_HTTP_URL=
SMS_HTTP_METHOD=POST
SMS_HTTP_HEADERS_JSON={}
SMS_HTTP_QUERY_TEMPLATE={}
SMS_HTTP_BODY_TEMPLATE=
SMS_HTTP_SUCCESS_STATUS=200,201,202
SMS_HTTP_TIMEOUT_SECONDS=10

DEFAULT_PAGE=1
DEFAULT_SIZE=10
LOG_LEVEL=INFO
