{
  "info": {
    "name": "Report Backend JSON Verification",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8000" },
    { "key": "token", "value": "user-token" },
    { "key": "adminToken", "value": "admin-token" },
    { "key": "superToken", "value": "super-token" }
  ],
  "item": [
    {
      "name": "01 Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('json envelope', () => { pm.expect(json.code).to.eql(200); pm.expect(json.message).to.eql('ok'); pm.expect(json).to.have.property('traceId'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "02 Create Report",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"reportName\":\"XX电厂迎峰度夏检查报告\",\"reportType\":\"summerCheck\",\"topic\":\"迎峰度夏安全检查\",\"major\":\"电气\",\"plant\":\"XX电厂\",\"year\":2026}"
        },
        "url": "{{baseUrl}}/api/reports"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('business ok', () => { pm.expect(json.code).to.eql(200); pm.expect(json.message).to.eql('ok'); pm.expect(json).to.have.property('traceId'); });",
              "pm.test('report id returned', () => pm.expect(json.data.reportId).to.match(/^rpt_/));",
              "pm.collectionVariables.set('reportId', json.data.reportId);"
            ]
          }
        }
      ]
    },
    {
      "name": "03 List Reports",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/reports?page=1&size=10&keyword=迎峰度夏&reportType=summerCheck"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.test('business ok', () => { pm.expect(json.code).to.eql(200); pm.expect(json.message).to.eql('ok'); pm.expect(json.data).to.have.property('items'); pm.expect(json.data).to.have.property('total'); pm.expect(json).to.have.property('traceId'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "04 Report Detail",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/reports/{{reportId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.test('detail shape', () => { pm.expect(json.code).to.eql(200); pm.expect(json.data).to.have.property('report'); pm.expect(json.data).to.have.property('outline'); pm.expect(json.data).to.have.property('contents'); pm.expect(json.data).to.have.property('latestExport'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "05 Generate Outline",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"reportType\":\"summerCheck\",\"topic\":\"迎峰度夏安全检查\",\"templateId\":\"tpl_001\"}"
        },
        "url": "{{baseUrl}}/api/reports/{{reportId}}/outline/generate"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.test('outline ok', () => { pm.expect(json.code).to.eql(200); pm.expect(json.data.outline.length).to.be.above(0); pm.expect(json).to.have.property('traceId'); });",
              "pm.collectionVariables.set('chapterId', json.data.outline[0].chapterId);"
            ]
          }
        }
      ]
    },
    {
      "name": "06 Save Chapter Content",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"content\":\"用户编辑后的章节正文。\",\"tables\":[{\"tableId\":\"tbl_001\",\"title\":\"设备检查情况表\",\"headers\":[\"序号\",\"设备\",\"问题\",\"整改建议\"],\"rows\":[[\"1\",\"主变压器\",\"温度偏高\",\"加强巡检\"]]}],\"manualEdited\":true}"
        },
        "url": "{{baseUrl}}/api/reports/{{reportId}}/chapters/{{chapterId}}/content"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.test('save content ok', () => { pm.expect(json.code).to.eql(200); pm.expect(json.data.status).to.eql('done'); pm.expect(json).to.have.property('traceId'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "07 Create Export",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"templateId\":\"tpl_001\",\"fileFormat\":\"docx\",\"useLatestSavedContent\":true}"
        },
        "url": "{{baseUrl}}/api/reports/{{reportId}}/exports"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.test('export create ok', () => { pm.expect(json.code).to.eql(200); pm.expect(json.data.exportId).to.match(/^exp_/); pm.expect(json).to.have.property('traceId'); });",
              "pm.collectionVariables.set('exportId', json.data.exportId);"
            ]
          }
        }
      ]
    },
    {
      "name": "08 Export Status",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/reports/{{reportId}}/exports/{{exportId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.test('export status ok', () => { pm.expect(json.code).to.eql(200); pm.expect(json.data.status).to.eql('exported'); pm.expect(json.data.downloadUrl).to.include('/download'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "09 Admin Model Config",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "url": "{{baseUrl}}/api/admin/model-config"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.test('model config ok and masked', () => { pm.expect(json.code).to.eql(200); pm.expect(json.data).to.have.property('apiKeyMasked'); pm.expect(json.data).to.not.have.property('apiKey'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "10 User Forbidden Templates",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/templates"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.test('forbidden json', () => { pm.expect(json.code).to.eql(403); pm.expect(json).to.have.property('traceId'); });"
            ]
          }
        }
      ]
    }
  ]
}
